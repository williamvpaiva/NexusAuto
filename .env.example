# ============================================
# GENERAL
# ============================================

# NODE_ENV - Ambiente de execução
# Tipo: string | Obrigatório: sim | Valores: development | production | test
NODE_ENV=development

# ============================================
# OPENWA (WhatsApp API Gateway)
# ============================================

# OPENWA_API_KEY - Chave secreta para autenticar no gateway WhatsApp
# Tipo: string | Obrigatório: sim
# Link: https://openwa.dev/docs
OPENWA_API_KEY=your-super-secret-api-key-here

# OPENWA_BASE_URL - URL base do servidor OpenWA
# Tipo: string | Obrigatório: sim | Padrão: http://localhost:2785
OPENWA_BASE_URL=http://localhost:2785

# OPENWA_WEBHOOK_BASE_URL - URL pública para webhooks do WhatsApp
# Tipo: string | Obrigatório: sim
OPENWA_WEBHOOK_BASE_URL=http://nexusauto-backend:3000

# ============================================
# MCP (Model Context Protocol)
# ============================================

# MCP_ENABLED - Ativa o servidor MCP para agentes de IA
# Tipo: boolean | Obrigatório: não | Padrão: true
MCP_ENABLED=true

# MCP_READONLY - Modo somente leitura do MCP
# Tipo: boolean | Obrigatório: não | Padrão: false
MCP_READONLY=false

# MCP_RATE_LIMIT_MAX - Máximo de requisições por janela de tempo
# Tipo: number | Obrigatório: não | Padrão: 100
MCP_RATE_LIMIT_MAX=100

# MCP_RATE_LIMIT_WINDOW_MS - Janela de rate limit em milissegundos
# Tipo: number | Obrigatório: não | Padrão: 60000
MCP_RATE_LIMIT_WINDOW_MS=60000
