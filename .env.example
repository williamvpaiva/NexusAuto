# Variáveis de Ambiente

## Aplicação
APP_NAME=polymarketing
APP_ENV=development
APP_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=/api/v1

## Banco de Dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polymarketing_db
DB_USER=polymarketing_user
DB_PASSWORD=polymarketing_password

## Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

## Segurança
JWT_SECRET=mude_este_segredo_em_producao
JWT_EXPIRES_IN=7d

## Logs
LOG_LEVEL=info

## Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100