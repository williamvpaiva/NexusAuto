# Configuração do Dashboard Líder

# Porta da API (backend)
DASHBOARD_API_PORT=3001

# Porta do Web Server (frontend)
DASHBOARD_WEB_PORT=3000

# Intervalo de auto-refresh em segundos
AUTO_REFRESH_INTERVAL=30

# Habilitar WebSocket (future feature)
WEBSOCKET_ENABLED=false

# Logs
LOG_LEVEL=info
LOG_FILE=dashboard.log