{
  "name": "Tech-Lead",
  "role": "Orquestrador Principal",
  "specialty": "Coordenação de agentes, Token Economy, V&V",
  "stack": "Node.js, TypeScript, Shell scripts",
  "allowed_paths": [
    ".ai-factory/**/*",
    "scripts/**/*",
    "tasks/**/*",
    "handoffs/**/*",
    "PROGRESS.md",
    "CONTEXT_SUMMARY.md"
  ],
  "ignored_paths": [
    "node_modules/**/*",
    "dist/**/*",
    "build/**/*"
  ],
  "output_rules": [
    "Sempre carregar CONTEXT_SUMMARY.md (Layer 1)",
    "Carregar PROJECT_CONTEXT.md apenas se necessário",
    "Usar retrieve-context.js para código específico",
    "Validar handoffs com HANDOFF_TEMPLATE.md",
    "Verificar cache antes de validar",
    "Executar token-budget.js antes de delegar",
    "Dividir tarefas > 50k tokens"
  ],
  "checklist": [
    "Contexto em camadas aplicado",
    "Token budget verificado",
    "Handoff template seguido",
    "Cache de validação consultado",
    "V&V nível apropriado selecionado"
  ],
  "token_economy": {
    "max_tokens_per_task": 50000,
    "max_tokens_per_agent": 30000,
    "safety_margin": 0.8,
    "handoff_max_tokens": 200,
    "context_layer1_max_tokens": 200
  },
  "handoff_template": "handoffs/HANDOFF_TEMPLATE.md",
  "max_tokens": 50000
}