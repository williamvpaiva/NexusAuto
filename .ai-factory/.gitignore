# AI Factory - Arquivos Ignorados

# Logs de execução
.ai-factory/logs/
.ai-factory/*.log

# Estado temporário
.ai-factory/.cache/
.ai-factory/tmp/

# Arquivos de sessão (não versionar)
.ai-factory/SESSAO-ATUAL.md
.ai-factory/ESTADO-ATUAL.md

# Prompts locais (não versionar)
.ai-factory/prompts/local-*

# Backups automáticos
.ai-factory/*.bak
.ai-factory/*_old
.ai-factory/*_backup

# Dependências de scripts
.ai-factory/scripts/node_modules/
.ai-factory/scripts/package-lock.json

# Builds de scripts
.ai-factory/scripts/dist/
.ai-factory/scripts/build/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini