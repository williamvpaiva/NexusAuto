// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tarefa {
  id        String   @id @default(uuid())
  title     String
  status    String   @default("PENDENTE") // PENDENTE, EM_PROGRESSO, CONCLUIDA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  payload   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("CLIENT") // ADMIN, MANAGER, SALES, CLIENT
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  leads        Lead[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  phone        String?
  email        String?
  source       String
  status       String   @default("NOVO") // NOVO, CONTATADO, QUALIFICADO, PERDIDO
  score        Int      @default(0)
  assignedToId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
}
